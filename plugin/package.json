{
  "name": "@sharper-flow/opencode-model-routing-plugin",
  "version": "0.1.0",
  "description": "OpenCode plugin for transparent per-agent model fallback. Reads plugin tuple fallback_models options and rotates through the chain on errors, TTFT timeout, or cooldown.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=24.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "NOTICE"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sharper-Flow/opencode-model-routing"
  },
  "scripts": {
    "build": "tsup",
    "prepack": "bun run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "OPENCODE_MODEL_ROUTING_COOLDOWN=/dev/null/omr-test-isolation bun test",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run test"
  },
  "dependencies": {
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@opencode-ai/plugin": "1.4.8",
    "@opencode-ai/sdk": "1.4.17",
    "@types/bun": "1.3.14",
    "@types/proper-lockfile": "^4.1.4",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0"
  }
}
